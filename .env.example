# ============================================
# 띠별 일일 운세 서비스 환경변수 템플릿
# 이 파일을 복사하여 .env 파일을 만드세요:
#   cp .env.example .env
# ============================================

# --- Database ---
# Prisma 데이터베이스 연결 문자열
# SQLite (로컬 개발): "file:./dev.db"
# PostgreSQL (프로덕션): "postgresql://user:password@host:5432/dbname"
DATABASE_URL="file:./dev.db"

# --- LLM API Key ---
# 운세 텍스트 자동 생성에 사용할 AI 모델 API 키 (택 1)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# --- KASI 공공데이터포털 API ---
# 한국천문연구원 음양력/특일 정보 API 인증키
# https://www.data.go.kr 에서 발급
KASI_API_KEY=""
